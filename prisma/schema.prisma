generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id        String   @id @default(uuid())
  title     String
  category  String
  imageUrl  String
  createdAt DateTime @default(now())
}

model Contact {
  id        String   @id @default(uuid())
  name      String
  email     String
  message   String
  createdAt DateTime @default(now())
}

model Stat {
  id     String @id @default(uuid())
  label  String
  value  Int
  suffix String @default("")
  order  Int
}

model Service {
  id          String @id @default(uuid())
  title       String
  description String
}
